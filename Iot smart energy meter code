// --------------------------------------
// Pins & Hardware Configuration
// --------------------------------------
#define RELAY_PIN 13          // D7 on NodeMCU - Controls the Load
SoftwareSerial pzemSWSerial(14, 12); // D5 (RX), D6 (TX)
PZEM004Tv30 pzem(pzemSWSerial);
LiquidCrystal_I2C lcd(0x27, 16, 2);

// --------------------------------------
// Credentials & Config
// --------------------------------------
const char* ssid = "OnePlus 10R ";
const char* password = "Bhoolgaya";
const char* mqtt_server = "broker.hivemq.com";
const int mqtt_port = 1883;

// SMS API (Circuit Digest / Twilio / etc.)
const char* apiKey = "yourapikey";    
const char* mobileNumber = "Yourphonenumber";
const char* templateID = "101";

unsigned long lastSMS = 0;
const unsigned long smsCooldown = 60000; // 1 minute
unsigned long lastUpdate = 0;
const long interval = 5000; // Publish every 5 seconds

WiFiClient espClient;
PubSubClient client(espClient);

// MQTT Topics
const char* tJSON = "unique/energy/data";
const char* tControl = "unique/energy/control"; // Topic to turn relay ON/OFF

// --------------------------------------
// SMS Alert Function
// --------------------------------------
void sendSMS(String reason) {
  WiFiClientSecure secureClient;
  secureClient.setInsecure(); 
  HTTPClient http;
  
  String apiUrl = "https://www.circuitdigest.cloud/api/v1/send_sms?ID=" + String(templateID);
  
  if (http.begin(secureClient, apiUrl)) {
    http.addHeader("Authorization", apiKey);
    http.addHeader("Content-Type", "application/json");

    String payload = "{\"mobiles\":\"" + String(mobileNumber) + 
                     "\",\"var1\":\"Energy Meter\",\"var2\":\"" + reason + "\"}";
    
    int code = http.POST(payload);
    Serial.printf("[SMS] Sent. Response: %d\n", code);
    http.end();
  }
}

// --------------------------------------
// MQTT Callback (For Control)
// --------------------------------------
void callback(char* topic, byte* payload, unsigned int length) {
  String message;
  for (int i = 0; i < length; i++) message += (char)payload[i];
  
  Serial.print("Message arrived [");
  Serial.print(topic);
  Serial.print("] ");
  Serial.println(message);

  if (String(topic) == tControl) {
    if (message == "ON") {
      digitalWrite(RELAY_PIN, LOW); // Usually Low-level trigger
      Serial.println("Relay ON");
    } else if (message == "OFF") {
      digitalWrite(RELAY_PIN, HIGH);
      Serial.println("Relay OFF");
    }
  }
}

// --------------------------------------
// WiFi & MQTT Setup
// --------------------------------------
void setup_wifi() {
  delay(10);
  Serial.print("\nConnecting to ");
  Serial.println(ssid);
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connected. IP: " + WiFi.localIP().toString());
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Attempting MQTT connection...");
    String clientId = "ESP8266Client-" + String(random(0xffff), HEX);
    if (client.connect(clientId.c_str())) {
      Serial.println("connected");
      client.subscribe(tControl);
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      delay(5000);
    }
  }
}

// --------------------------------------
// Setup
// --------------------------------------
void setup() {
  Serial.begin(115200);
  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, HIGH); // Default OFF
  
  Wire.begin(4, 5); // SDA=D2, SCL=D1
  lcd.init();
  lcd.backlight();
  lcd.print("IoT Energy Mon");

  setup_wifi();
  client.setServer(mqtt_server, mqtt_port);
  client.setCallback(callback);
}

// --------------------------------------
// Loop
// --------------------------------------
void loop() {
  if (!client.connected()) reconnect();
  client.loop();

  unsigned long now = millis();
  if (now - lastUpdate > interval) {
    lastUpdate = now;

    float V = pzem.voltage();
    float I = pzem.current();
    float P = pzem.power();
    float E = pzem.energy();
    float F = pzem.frequency();
    float PF = pzem.pf();

    if (isnan(V)) {
      Serial.println("Error reading sensor");
    } else {
      // Logic: Auto-cut power if Voltage is dangerously high
      if (V > 255.0) {
        digitalWrite(RELAY_PIN, HIGH); // Cut Power
        if (now - lastSMS > smsCooldown) {
          sendSMS("Overvoltage Cutoff");
          lastSMS = now;
        }
      }

      // JSON Payload
      String json = "{";
      json += "\"V\":" + String(V, 1) + ",";
      json += "\"I\":" + String(I, 3) + ",";
      json += "\"P\":" + String(P, 1) + ",";
      json += "\"E\":" + String(E, 3);
      json += "}";
      client.publish(tJSON, json.c_str());

      // LCD Display
      lcd.clear();
      lcd.setCursor(0,0);
      lcd.print("V:"); lcd.print(V,1);
      lcd.setCursor(8,0);
      lcd.print("I:"); lcd.print(I,2);
      lcd.setCursor(0,1);
      lcd.print("P:"); lcd.print(P,1); lcd.print("W");
    }
  }
}


   
